<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.forge.dc.note.mapper.NoteMapper">

    <insert id="addNote" parameterType="com.forge.dc.note.entity.NoteEntity">
        insert into note (
        content,
        created_at,
        updated_at
        )
        values (
        #{content},
        #{createdAt},
        #{updatedAt}
        )
    </insert>

    <select id="getNoteList" resultType="com.forge.dc.note.entity.NoteEntity">
        select
        id,
        content,
        created_at,
        updated_at
        from note
        order by id desc
    </select>

</mapper>