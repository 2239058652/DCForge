<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.forge.dc.modules.ai.mapper.AiImageHistoryMapper">

    <select id="selectPage" resultType="com.forge.dc.modules.ai.entity.AiImageHistoryEntity">
        SELECT *
        FROM ai_image_history
        <where>
            user_id = #{userId}
            <if test="type != null and type != ''">
                AND type = #{type}
            </if>
        </where>
        ORDER BY created_at DESC
    </select>

</mapper>
