<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.forge.dc.modules.ai.mapper.AiTaskMapper">

    <select id="selectPage" resultType="com.forge.dc.modules.ai.entity.AiTaskEntity">
        SELECT *
        FROM ai_task
        <where>
            user_id = #{userId}
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        ORDER BY created_at DESC
    </select>

</mapper>
